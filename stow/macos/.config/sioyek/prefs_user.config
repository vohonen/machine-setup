# Port of the zathurarc intent (half-page d/u nav + yellow highlight).
# sioyek's config syntax differs from zathura - verify key/command names on-device against
# /opt/homebrew/share/sioyek/prefs.config if any of these are no-ops.

# half-page vertical movement (zathura had: map d scroll half-down / u scroll half-up)
move_screen_down d
move_screen_up u

# selection -> system clipboard / highlight color
should_use_multiple_monitors 0
highlight_color 1.0 1.0 0.0
