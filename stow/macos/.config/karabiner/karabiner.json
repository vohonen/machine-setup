{
    "profiles": [
        {
            "name": "Default",
            "selected": true,
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock → Escape (tap) / Control (hold)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control", "lazy": true }],
                                "to_if_alone": [
                                    { "key_code": "escape" },
                                    { "set_variable": { "name": "skim_search", "value": 0 } }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Ctrl+Alt+P → power chooser dialog (Sleep / Shut Down)",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "p",
                                    "modifiers": { "mandatory": ["control", "option"] }
                                },
                                "to": [{ "shell_command": "osascript ~/.config/karabiner/power-chooser.applescript" }]
                            }
                        ]
                    },
                    {
                        "description": "Skim: vim navigation, / search, z zoom toggle",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": { "key_code": "j" },
                                "to": [{ "key_code": "down_arrow" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "k" },
                                "to": [{ "key_code": "up_arrow" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "h" },
                                "to": [{ "key_code": "left_arrow" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "l" },
                                "to": [{ "key_code": "right_arrow" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "d", "modifiers": { "mandatory": ["control"] } },
                                "to": [{ "key_code": "page_down" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "u", "modifiers": { "mandatory": ["control"] } },
                                "to": [{ "key_code": "page_up" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "slash" },
                                "to": [
                                    { "key_code": "f", "modifiers": ["left_command"] },
                                    { "set_variable": { "name": "skim_search", "value": 1 } }
                                ],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "escape" },
                                "to": [
                                    { "set_variable": { "name": "skim_search", "value": 0 } },
                                    { "key_code": "escape" }
                                ],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 1 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "g" },
                                "to": [
                                    { "shell_command": "osascript -e 'tell application \"System Events\" to tell process \"Skim\" to click menu item \"First\" of menu \"Go\" of menu bar 1'" },
                                    { "set_variable": { "name": "skim_g", "value": 0 } }
                                ],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 },
                                    { "type": "variable_if", "name": "skim_g", "value": 1 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "g" },
                                "to": [{ "set_variable": { "name": "skim_g", "value": 1 } }],
                                "to_delayed_action": {
                                    "to_if_invoked": [{ "set_variable": { "name": "skim_g", "value": 0 } }],
                                    "to_if_canceled": [{ "set_variable": { "name": "skim_g", "value": 0 } }]
                                },
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "g", "modifiers": { "mandatory": ["shift"] } },
                                "to": [{ "shell_command": "osascript -e 'tell application \"System Events\" to tell process \"Skim\" to click menu item \"Last\" of menu \"Go\" of menu bar 1'" }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "n" },
                                "to": [{ "key_code": "g", "modifiers": ["left_command"] }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "n", "modifiers": { "mandatory": ["shift"] } },
                                "to": [{ "key_code": "g", "modifiers": ["left_command", "left_shift"] }],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "z" },
                                "to": [
                                    { "shell_command": "osascript -e 'tell application \"System Events\" to tell process \"Skim\" to click menu item \"Zoom To Fit\" of menu \"PDF\" of menu bar 1'" },
                                    { "set_variable": { "name": "skim_zoom_fit", "value": 1 } }
                                ],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 },
                                    { "type": "variable_if", "name": "skim_zoom_fit", "value": 0 }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": { "key_code": "z" },
                                "to": [
                                    { "shell_command": "osascript -e 'tell application \"System Events\" to tell process \"Skim\" to click menu item \"Actual Size\" of menu \"PDF\" of menu bar 1'" },
                                    { "set_variable": { "name": "skim_zoom_fit", "value": 0 } }
                                ],
                                "conditions": [
                                    { "type": "frontmost_application_if", "bundle_identifiers": ["^net\\.sourceforge\\.skim-app\\.skim$"] },
                                    { "type": "variable_if", "name": "skim_search", "value": 0 },
                                    { "type": "variable_if", "name": "skim_zoom_fit", "value": 1 }
                                ]
                            }
                        ]
                    }
                ]
            },
            "virtual_hid_keyboard": { "keyboard_type_v2": "iso" }
        }
    ]
}
